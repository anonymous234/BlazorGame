@page "/"
@using System.Text.Json
@namespace BlazorGame
<PageTitle>Home</PageTitle>
@*
Protip: if you have to insert a text element inside a C# code block, you have to escape it with @:, like this:
@if (...) {
    @:<text ...>Game over</text>
}
*@
<svg width="1200" height="600"
     id="game-field"
     class="game-field"
     viewBox="0 0 1200 600"
     preserveAspectRatio="xMidYMid meet"
     style="border:1px solid #222; background:#071019; touch-action:none;">
    <rect x="0" y="0" width="100%" height="100%" fill="#071019"></rect>
    <circle cx="@Inv(PlayerX)" cy="@Inv(PlayerY)" r="20" fill="tomato"/>
    <text x="10" y="20" fill="#ccc">Use arrow keys to move or pointer to position</text>
</svg>
<p>
    @StatusText
</p>

@code {
    readonly HashSet<string> currentKeys = [];
    double cursorX = 400;
    double cursorY = 300;
    bool mouseMoved = false;

    static string Inv(double value) => value.ToString(System.Globalization.CultureInfo.InvariantCulture);

    string StatusText = "";
    double PlayerX = 400;
    double PlayerY = 300;
    const double Speed = 220; // px/s

    public static void Method(object returnVal)
    {
        Console.WriteLine("Hello from C#!" + returnVal.GetType() + ": " + returnVal.ToString());
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            BrowserInterop.GameInit("", OnInput);
            AnimationFrameHook.BrowserAnimationFrame += OnFrame;
        }
    }

    public void OnInput(string values)
    {
        var doc = JsonDocument.Parse(values).RootElement;
        string type = doc.GetProperty("type").GetString()!;
        string? key = doc.TryGetProperty("key", out var val) ? val.GetString() : null;
        switch (type)
        {
            case "pointermove":
            case "pointerdown":
                mouseMoved = true;
                cursorX = doc.GetProperty("x").GetDouble();
                cursorY = doc.GetProperty("y").GetDouble();
                break;
            case "keydown":
                currentKeys.Add(key!);
                break;
            case "keyup":
                currentKeys.Remove(key!);
                break;
        }
    }

    double? lastTimestamp;

    public void OnFrame(object? _, AnimationFrameHook.BrowserAnimationFrameEventArgs args)
    {
        double dt;
        if (lastTimestamp == null) dt = 0;
        else dt = (args.Timestamp - lastTimestamp.Value) / 1000.0; //seconds
        lastTimestamp = args.Timestamp;

        if (mouseMoved)
        {
            PlayerX = cursorX;
            PlayerY = cursorY;
            mouseMoved = false;
        }

        var dx = 0.0;
        var dy = 0.0;
        if (currentKeys.Contains("ArrowLeft")) dx -= 1;
        if (currentKeys.Contains("ArrowRight")) dx += 1;
        if (currentKeys.Contains("ArrowUp")) dy -= 1;
        if (currentKeys.Contains("ArrowDown")) dy += 1;
        if (dx != 0 || dy != 0)
        {
            var len = Math.Sqrt(dx * dx + dy * dy);
            PlayerX += (dx / len) * Speed * dt;
            PlayerY += (dy / len) * Speed * dt;
        }
        StatusText = $"({PlayerX:F2}, {PlayerY:F2}) - ";
        foreach(string key in currentKeys) StatusText += $"{key}, ";
        InvokeAsync(StateHasChanged);
    }
}
